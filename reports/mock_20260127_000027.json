_type=test_type,\n            seed=seed,\n            patient_raw=patient_raw,\n            register_api=register_api,\n            cancel_api=cancel_api,\n            query_api=query_api,\n            verbose_fail=True,\n        )\n        if not r.ok:\n>           raise AssertionError(r.reason or \"step execution failed\")\nE           AssertionError: status_code 不符合 expect_status | expected=404 got=400\n\nutils\\data_utils\\executor.py:247: AssertionError"
